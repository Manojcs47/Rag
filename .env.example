# Copy to `.env` and adjust. All vars use the RN_ prefix. `.env` is gitignored.

# --- Corpus (kept out of git) ---
# Defaults assume the corpus is unpacked at the repo root as
# `ai-research-navigator-corpus/`. Point these elsewhere if you keep it outside
# the repo (e.g. RN_CORPUS_DIR=/data/ai-research-navigator-corpus).
RN_CORPUS_DIR=ai-research-navigator-corpus
RN_MANIFEST_PATH=ai-research-navigator-corpus/manifest.json

# --- Qdrant (ADR: storage) ---
# Use a running server for real ingestion; ':memory:' is for quick local trials/tests.
RN_QDRANT_URL=http://localhost:6333
RN_QDRANT_COLLECTION=research_navigator

# --- Dense embeddings (ADR-0001: local open-source via sentence-transformers) ---
RN_DENSE_MODEL=BAAI/bge-small-en-v1.5
RN_DENSE_DIM=384
RN_DENSE_DEVICE=cpu          # set to 'cuda' if you have a GPU
RN_EMBED_BATCH_SIZE=64
# bge passages need no prefix; for an e5 model set: RN_PASSAGE_PREFIX="passage: "

# Offline, deterministic hashing embedder — NO model download. For CI/tests only,
# not for production retrieval quality. Leave false for real ingestion.
RN_USE_OFFLINE_EMBEDDER=false

# --- Sparse retrieval (ADR-0004: TF vectors + Qdrant IDF == BM25) ---
RN_SPARSE_VOCAB_SIZE=262144

# --- Chunking (ADR-0003); nested params use the __ delimiter ---
# e.g. raise the arXiv budget:
# RN_CHUNK__ARXIV_PAPER__MAX_TOKENS=600
# RN_CHUNK__ARXIV_PAPER__OVERLAP_TOKENS=80

# --- Reproducibility / logging ---
RN_SEED=42
RN_LOG_LEVEL=INFO
RN_JSON_LOGS=false           # true -> JSON logs to stderr (stdout stays clean for CLI JSON)
